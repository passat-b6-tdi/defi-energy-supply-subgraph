specVersion: 0.0.1
description: Defi Energy Supply. v0.0.1
repository: https://github.com/b0gdaniy/defi-energy-supply-subgraph
schema:
  file: ./{{ schemaFileName }}
dataSources:
{{ #dataSources.Register }}
  - kind: ethereum/contract
    name: Register
    network: {{ network }}
    source:
      address: "{{ dataSources.Register.address }}"
      abi: Register
      startBlock: {{ dataSources.Register.startBlock }}
    mapping:
      kind: ethereum/events
      apiVersion: 0.0.7
      language: wasm/assemblyscript
      file: ./src/mappings/register.ts
      entities:
        - Producer
        - Supplier
        - Consumer
      abis:
        - name: Register
          file: ./abis/Register.json
      eventHandlers:
        - event: ProducerRegistered(indexed address,indexed address,indexed uint256,uint256)
          handler: handleProducerRegistered
        - event: ProducerUnregistered(indexed address,indexed uint256,uint256)
          handler: handleProducerUnregistered
        - event: SupplierRegistered(indexed address,indexed address,indexed uint256,uint256)
          handler: handleSupplierRegistered
        - event: SupplierUnregistered(indexed address,indexed uint256,uint256)
          handler: handleSupplierUnregistered
        - event: ConsumerRegistered(indexed address,indexed address,indexed uint256,uint256)
          handler: handleUserRegistered
        - event: ConsumerUnregistered(indexed address,indexed address,indexed uint256,uint256)
          handler: handleUserUnregistered
{{ /dataSources.Register }}
{{ #dataSources.EnergyOracle }}
  - kind: ethereum/contract
    name: EnergyOracle
    network: {{ network }}
    source:
      address: "{{ dataSources.EnergyOracle.address }}"
      abi: EnergyOracle
      startBlock: {{ dataSources.EnergyOracle.startBlock }}
    mapping:
      kind: ethereum/events
      apiVersion: 0.0.7
      language: wasm/assemblyscript
      file: ./src/mappings/energy-oracle.ts
      entities:
        - EnergyProduction
        - EnergyConsumption
      abis:
        - name: EnergyOracle
          file: ./abis/EnergyOracle.json
      eventHandlers:
        - event: EnergyConsumptionRecorded(indexed address,indexed address,indexed uint256,uint256,uint256)
          handler: handleEnergyConsumptionRecorded
        - event: EnergyConsumptionUpdated(indexed address,indexed address,indexed uint256,uint256,uint256,uint256)
          handler: handleEnergyConsumptionUpdated
        - event: EnergyProductionRecorded(indexed address,indexed address,indexed uint256,uint256,uint256)
          handler: handleEnergyProductionRecorded
{{ /dataSources.EnergyOracle }}
